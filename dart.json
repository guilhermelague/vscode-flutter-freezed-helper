{
  "Create a Freezed Class": {
    "prefix": "frc",
    "body": [
      "@freezed",
      "abstract class $1 with _$$1 {",
      "",
      "\tconst factory $1({",
      "\t\trequired String id,",
      "\t}) = _$1;",
      "",
      "\tfactory $1.fromJson(Map<String, dynamic> json) =>",
      "\t\t\t_$$1FromJson(json);",
      "}"
    ],
    "description": "Creates a Freezed 2.x / Dart 3 compatible class. Uses abstract class, const factory and named parameters."
  },
  "Setup file for freezed annotation & Code Gen": {
    "prefix": "frf",
    "body": [
      "import 'package:freezed_annotation/freezed_annotation.dart';",
      "",
      "part '$TM_FILENAME_BASE.freezed.dart';",
      "part '$TM_FILENAME_BASE.g.dart';",
      "",
      "@freezed",
      "abstract class $1 with _$$1 {",
      "",
      "\tconst factory $1({",
      "\t\trequired String id,",
      "\t}) = _$1;",
      "",
      "\tfactory $1.fromJson(Map<String, dynamic> json) =>",
      "\t\t\t_$$1FromJson(json);",
      "}"
    ],
    "description": "Sets up a Dart file with Freezed 2.x / Dart 3 compatible imports, part directives and a model class."
  },
  "Create a Freezed Class with private constructor": {
    "prefix": "frcp",
    "body": [
      "@freezed",
      "abstract class $1 with _$$1 {",
      "\tconst $1._();",
      "",
      "\tconst factory $1({",
      "\t\trequired String id,",
      "\t}) = _$1;",
      "",
      "\tfactory $1.fromJson(Map<String, dynamic> json) =>",
      "\t\t\t_$$1FromJson(json);",
      "",
      "\t$0",
      "}"
    ],
    "description": "Creates a Freezed class with a private constructor, enabling custom methods and getters. Useful for model-to-entity conversion."
  },
